# ── Edge Gateway Dashboard — Local dev vars ───────────────────────────────
# These are only used for local development (node server.js).
# For Railway deployment, set these as service variables in the dashboard.
# Also available at: Settings → Worker Runtime Config

# ── Supabase (managed Postgres) ──────────────────────────────────────────
SUPABASE_URL=https://jpvjfxqzkmfzpqffuqbj.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImpwdmpmeHF6a21menBxZmZ1cWJqIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODI3MDk4NTcsImV4cCI6MjA5ODI4NTg1N30.NBmYkg9mLeF9EdBWQWWAgzC3PzUKz9G8bWndzsPsq00

# ── API Gateway ──────────────────────────────────────────────────────────
API_KEY=
BASE_DOMAIN=
PROXY_TARGET=

# ── Rork Toolkit AI proxy (Kimi K2.7 + Grok Build 0.1) ──────────────────
TOOLKIT_URL=https://toolkit.rork.com
TOOLKIT_SECRET_KEY=rork_sk_83hc0lvnsv5fqovbb1sb6uvhz7r4ip33

# ── Tunneling Backends ───────────────────────────────────────────────────
# Default: "direct" (built-in TCP/HTTP reverse proxy — always available)
# Options: "direct" | "pangolin" | "frp"
DEFAULT_TUNNEL_BACKEND=direct

# ── Pangolin (WireGuard-based self-hosted control plane) ────────────────
# Set PANGOLIN_CONTROL_PLANE to your Pangolin server URL (e.g. https://pangolin.yourdomain.com)
# Set PANGOLIN_AUTH_TOKEN to the API token from your Pangolin admin panel
PANGOLIN_CONTROL_PLANE=
PANGOLIN_AUTH_TOKEN=

# ── frp (Fast Reverse Proxy) ────────────────────────────────────────────
# Set FRPS_ADDR to your frps server hostname/IP
# Set FRPS_PORT to the frps bind port (default 7000)
# Set FRP_AUTH_TOKEN to the shared authentication token
FRPS_ADDR=
FRPS_PORT=7000
FRP_AUTH_TOKEN=
